# Database
DATABASE_URL=
# Redis (Upstash TLS format)
REDIS_URL=rediss://default:YOUR_TOKEN@your-host.upstash.io:6379
# AWS (optional for IoT Core)
AWS_REGION=eu-central-1
AWS_IOT_ENDPOINT=xxx.iot.region.amazonaws.com

# App
SECRET_KEY="
"
USE_ML_FOR_PROD=false

# Google OAuth (create credentials at https://console.cloud.google.com/apis/credentials)
# OAuth 2.0 Client ID → Web application → Add authorized redirect URIs
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com

# Data retention (days)
RAW_TELEMETRY_RETENTION_DAYS=30
TRIP_HISTORY_RETENTION_DAYS=365

# Google Maps (ETA)
GOOGLE_MAPS_API_KEY=xxx

# FCM (notifications)
FCM_SERVER_KEY=xxx

# --- Security ---
# CORS origins (comma-separated). Use specific domains in production.
CORS_ORIGINS=*

# Firewall
FIREWALL_ENABLED=true
BLOCKLIST_PATH=storage/firewall_blocklist.txt
FIREWALL_AUTO_BAN_THRESHOLD=100
FIREWALL_AUTO_BAN_WINDOW_SECONDS=300
FIREWALL_AUTO_BAN_DURATION_SECONDS=3600
FIREWALL_BURST_THRESHOLD=50
FIREWALL_BURST_WINDOW_SECONDS=10

# Trusted proxy IPs for X-Forwarded-For (comma-separated)
TRUSTED_PROXY_IPS=127.0.0.1,::1

# HSTS max-age in seconds (1 year = 31536000)
HSTS_MAX_AGE=31536000

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=noreply@bustrack.et

# Frontend base URL (for email verification/reset links)
APP_BASE_URL=http://localhost:3000
