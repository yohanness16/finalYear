# ──────────────────────────────────────────────────────────────────────────────
# BusTrack Terraform Variables — Example
# Copy to terraform.tfvars and fill in real values
# NEVER commit terraform.tfvars to git!
# ──────────────────────────────────────────────────────────────────────────────

project_name = "bustrack"
environment  = "prod"
location     = "eastus"

# B1 = basic tier (cheapest with always-on), P1v2 = production
app_service_sku = "B1"

# Docker image — will be pushed to the ACR created by Terraform
# Format: <acr-name>.azurecr.io/<image-name>:latest
docker_image = "bustrackacr.azurecr.io/bustrack-api:latest"

# ── Supabase ──
# Get from Supabase Dashboard → Settings → Database → Connection string
# Use the asyncpg-compatible format:
# postgresql+asyncpg://postgres:PASSWORD@db.xxx.supabase.co:5432/postgres
supabase_db_url = "postgresql+asyncpg://postgres:YOUR_PASSWORD@db.xxx.supabase.co:5432/postgres"

# ── Upstash Redis ──
# Get from Upstash Console → Your Redis → Details
# Host: xxx-xxx-xxx.upstash.io  (just the hostname, no https://)
upstash_redis_host  = "xxx-xxx-xxx.upstash.io"
upstash_redis_token = "YOUR_UPSTASH_REST_TOKEN"

# ── Resend ──
# Get from resend.com/api-keys
resend_api_key    = "re_xxxxxxxxxxxxx"
resend_from_email = "noreply@bustrack.dpdns.org"

# ── Google OAuth ──
# Get from Google Cloud Console → APIs & Services → Credentials → OAuth Client ID
google_client_id = "xxx.apps.googleusercontent.com"

# ── App Secrets ──
# Generate with: openssl rand -hex 32
secret_key = "your-jwt-secret-key-here-min-32-chars"

# Frontend URL for email links
app_base_url = "https://bustrack.dpdns.org"

# CORS origins (your frontend + backend domains)
cors_origins = "https://bustrack.dpdns.org,https://api.bustrack.dpdns.org"
